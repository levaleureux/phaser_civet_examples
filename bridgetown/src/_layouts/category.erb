<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Category | Phaser Examples</title>
    <link rel="stylesheet" href="/assets/css/main.css?v=<%= Time.now.to_i %>">
    <%= live_reload_dev_js %>
</head>
<body>
    <div class="copper-bg"></div>

    <header>
        <div class="container">
            <div class="header-content">
                <div class="logo-container">
                    <div class="logo phaser">P</div>
                    <span style="color: #b4b4c8; font-size: 2rem;">+</span>
                    <div class="logo civet">C</div>
                </div>
                <h1 class="title">Phaser Examples</h1>
            </div>
        </div>
    </header>

    <main>
        <section class="examples-preview">
            <div class="container">
                <h2>Actions Examples</h2>
                <p class="examples-subtitle">
                    Examples in the actions category
                </p>
                <div class="examples-grid">
                    <div class="example-item">
                        <img src="/assets/examples/actions/examples/example1/thumb.png" alt="Example 1" class="category-image">
                        <div class="category-content">
                            <h4><a href="/examples/actions/example1.html">Example 1</a></h4>
                            <p>Phaser example in CivetScript</p>
                        </div>
                    </div>
                    <div class="example-item">
                        <img src="/assets/examples/actions/examples/example2/thumb.png" alt="Example 2" class="category-image">
                        <div class="category-content">
                            <h4><a href="/examples/actions/example2.html">Example 2</a></h4>
                            <p>Phaser example in CivetScript</p>
                        </div>
                    </div>
                </div>
                <div class="view-all-examples">
                    <a href="/">Back to Home</a>
                </div>
            </div>
        </section>
    </main>

    <footer>
        <div class="container">
            <div class="footer-content">
                <a href="https://phaser.io" class="footer-link">Phaser.io</a>
                <a href="https://civet.dev" class="footer-link">Civet.dev</a>
                <a href="https://github.com/levaleureux/phaser_civet_examples" class="footer-link">GitHub</a>
            </div>
        </div>
    </footer>
</body>
</html>