<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Example | Phaser Examples</title>
    <link rel="stylesheet" href="/assets/css/main.css?v=<%= Time.now.to_i %>">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism.min.css">
    <%= live_reload_dev_js %>
</head>
<body>
    <div class="copper-bg"></div>

    <header>
        <div class="container">
            <div class="header-content">
                <div class="logo-container">
                    <div class="logo phaser">P</div>
                    <span style="color: #b4b4c8; font-size: 2rem;">+</span>
                    <div class="logo civet">C</div>
                </div>
                <h1 class="title">Phaser Examples</h1>
            </div>
        </div>
    </header>

    <main>
        <div class="example-container">
            <h1><%= data.name || data.title %></h1>
            <div class="example-content">
                <div class="example-code">
                    <h2>Code</h2>
                            <% civet_path = "src" + data.js_path.split("/")[0..-2].join("/") + "/converted.civet" %>
                            <%= civet_path %>
                            <br>
                              <%= Dir.pwd %>
                            <br>
                            <% if File.exist?(civet_path)  %>
                              <%= File.read civet_path  %>
                            <% else %>
                              civet not avaliable
                            <% end %>
                            <br>
                            <br>
                    <div class="code-tabs">
                        <input id="js-tab" type="radio" name="code-tab" checked>
                        <label for="js-tab">JS</label>
                        <input id="civet-tab" type="radio" name="code-tab">
                        <label for="civet-tab">Civet</label>
                        <pre id="js-code"><code class="language-js">// Placeholder JS code</code></pre>
                        <pre id="civet-code">
                          <code class="language-civet">

                            <% if File.exist?(civet_path)  %>
                              <%= File.read civet_path %>
                            <% else %>
                              hello civet
                            <% end %>
                          </code>
                        </pre>
                    </div>
                </div>
                <div class="example-preview">
                    <h2>Preview</h2>
                    <div id="phaser-example"></div>
                </div>
            </div>
        </div>
    </main>

    <footer>
        <div class="container">
            <div class="footer-content">
                <a href="https://phaser.io" class="footer-link">Phaser.io</a>
                <a href="https://civet.dev" class="footer-link">Civet.dev</a>
                <a href="https://github.com/levaleureux/phaser_civet_examples" class="footer-link">GitHub</a>
            </div>
        </div>
    </footer>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/prism.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-javascript.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/phaser@3.85.0/dist/phaser.min.js"></script>
    <script src="<%= data.js_path %>"></script>

    <script>
    document.addEventListener('DOMContentLoaded', () => {
        fetch('<%= data.js_path %>')
            .then(response => response.text())
            .then(code => {
                document.getElementById('js-code').innerHTML = `<code class="language-js">${code.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</code>`;
                if (window.Prism) {
                    Prism.highlightElement(document.querySelector('#js-code code'));
                }
            })
            .catch(err => {
                document.getElementById('js-code').innerHTML = '<code>Error loading code.</code>';
                console.error(err);
            });
    });
    </script>
</body>
</html>
